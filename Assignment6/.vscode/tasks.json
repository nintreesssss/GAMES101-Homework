{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: g++.exe 生成活动文件",
			"command": "D:\\mingw64\\bin\\g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"-ID:\\vcpkg\\installed\\x64-mingw-dynamic\\include",
				"-ID:\\vcpkg\\installed\\x64-mingw-dynamic\\include\\opencv4",
				"-ID:\\vcpkg\\installed\\x64-mingw-dynamic\\include\\opencv4\\opencv2",
				"*.cpp",
				"-LD:\\vcpkg\\installed\\x64-mingw-dynamic\\lib",
				"-lopencv_core4",
				"-lopencv_imgproc4",
				"-lopencv_highgui4",
				"-lopencv_imgcodecs4",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "编译器: D:\\mingw64\\bin\\g++.exe"
		}
	]
}