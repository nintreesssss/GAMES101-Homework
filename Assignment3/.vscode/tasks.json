{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "D:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-O2",
                "-I",
                "D:/vcpkg/installed/x64-mingw-dynamic/include",
                "-I",
                "D:/vcpkg/installed/x64-mingw-dynamic/include/opencv4",
                "-I",
                "D:/vcpkg/installed/x64-mingw-dynamic/include/eigen3",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\rasterizer.cpp",
                "${workspaceFolder}\\Triangle.cpp",
                "-L",
                "D:/vcpkg/installed/x64-mingw-dynamic/lib",
                "-lopencv_core4",
                "-lopencv_imgproc4",
                "-lopencv_highgui4",
                "-lopencv_imgcodecs4",
                "-o",
                "${workspaceFolder}\\rasterizer.exe"
            ],
            "options": {
                "cwd": "D:/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}